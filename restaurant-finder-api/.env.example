# restaurant-finder-api/.env.example
AWS_REGION=ap-south-1
AWS_PROFILE=bedrock-dev

# Preferred: set this to your inference profile ID/ARN when you have one.
# Example ID: apac.anthropic.claude-3-5-sonnet-20241022-v2:0
# Example ARN: arn:aws:bedrock:ap-south-1:<account-id>:inference-profile/<name>
BEDROCK_INFERENCE_PROFILE_ID=

# Direct model fallback when no inference profile is set.
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
